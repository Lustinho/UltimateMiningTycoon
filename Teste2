-- =============================================
-- Botão Pequeno Arrastrável ON/OFF (Mobile Friendly)
-- =============================================

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- ==================== CARREGAR LIBRARIES ====================
local Library = loadstring(game:HttpGet("https://gist.githubusercontent.com/VertigoCool99/282c9e98325f6b79299c800df74b2849/raw/d9efe72dc43a11b5237a43e2de71b7038e8bb37b/library.lua"))()
-- ==================== CONFIGURAÇÕES SIMPLES ====================
local Settings = {
    AutoMine = false,
    AutoSell = false,
    MiningRange = 120,
    OreHitbox = false,
    HitboxSize = 8,
    ShowNames = false,
    ShowDistance = false,
}

local Tool = nil

local function GetTool()
    for _, v in pairs(character:GetChildren()) do
        if v:FindFirstChild("EquipRemote") or string.find(v.Name:lower(), "pickaxe") then
            return v
        end
    end
    return nil
end

-- Farming Group
local FarmGroup = MainTab:AddLeftGroupbox("Farming")

FarmGroup:AddToggle("AutoMine", {Text = "Auto Mine", Default = false})
    :OnChanged(function(v) Settings.Farming.AutoMine = v end)

FarmGroup:AddToggle("AutoSell", {Text = "Auto Sell", Default = false})
    :OnChanged(function(v) Settings.Farming.AutoSell = v end)

FarmGroup:AddSlider("MiningRange", {Text = "Mining Range", Default = 150, Min = 50, Max = 400})
    :OnChanged(function(v) Settings.Farming.AutoMineRange = v end)

FarmGroup:AddToggle("OreHitbox", {Text = "Ore Hitbox", Default = false})
    :OnChanged(function(v)
        Settings.Farming.OreHitboxes = v
        for _, ore in pairs(Workspace.SpawnedBlocks:GetChildren()) do
            if ore:IsA("MeshPart") then
                ore.Size = v and Vector3.new(Settings.Farming.OreHitboxesSize, Settings.Farming.OreHitboxesSize, Settings.Farming.OreHitboxesSize) or Vector3.new(4.4,4.4,4.4)
            end
        end
    end)

-- Cria a ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "MobileToggleButton"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

-- Cria o botão circular pequeno
local button = Instance.new("TextButton")
button.Name = "ToggleButton"
button.Size = UDim2.new(0, 65, 0, 65)           -- tamanho pequeno
button.Position = UDim2.new(1, -85, 0, 20)      -- canto superior direito (pode mudar)
button.BackgroundColor3 = Color3.fromRGB(220, 0, 0)  -- começa vermelho (OFF)
button.Text = "OFF"
button.TextColor3 = Color3.new(1, 1, 1)
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.BorderSizePixel = 0
button.Parent = screenGui

-- Deixa o botão redondo
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)   -- 100% arredondado = círculo
corner.Parent = button

-- Borda branca para ficar bonito
local stroke = Instance.new("UIStroke")
stroke.Thickness = 3
stroke.Color = Color3.new(1, 1, 1)
stroke.Transparency = 0.4
stroke.Parent = button

-- Variáveis de controle
local isOn = false

-- Função que muda o estado do botão
local function toggleButton()
    isOn = not isOn
    
    if isOn then
        button.BackgroundColor3 = Color3.fromRGB(0, 180, 0)   -- Verde
        button.Text = "ON"
        print("✅ Botão ativado (ON)")
        -- Aqui você pode colocar o que quiser que aconteça quando ligar
        -- Exemplo: EspLibrary.ItemNames.Enabled = true
    else
        button.BackgroundColor3 = Color3.fromRGB(220, 0, 0)   -- Vermelho
        button.Text = "OFF"
        print("⛔ Botão desativado (OFF)")
        -- Exemplo: EspLibrary.ItemNames.Enabled = false
    end
end

-- Clique no botão
button.MouseButton1Click:Connect(toggleButton)

-- ==================== SISTEMA DE ARRASTAR COM DEDO ====================
local dragging = false
local dragStart
local startPos

button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = button.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        button.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

button.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Mensagem inicial
print("🟢 Botão pequeno arrastável criado com sucesso!")
print("   • Toque para ligar/desligar (verde = ON | vermelho = OFF)")
print("   • Segure e arraste para mover o botão")
