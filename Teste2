-- Variáveis de controle
local isOn = false

-- Função que muda o estado do botão
local function toggleButton()
    isOn = not isOn
    
    if isOn then
        button.BackgroundColor3 = Color3.fromRGB(0, 180, 0)   -- Verde
        button.Text = "ON"
        print("✅ Botão ativado (ON)")
        -- Aqui você pode colocar o que quiser que aconteça quando ligar
        -- Exemplo: EspLibrary.ItemNames.Enabled = true
    else
        button.BackgroundColor3 = Color3.fromRGB(220, 0, 0)   -- Vermelho
        button.Text = "OFF"
        print("⛔ Botão desativado (OFF)")
        -- Exemplo: EspLibrary.ItemNames.Enabled = false
    end
end

-- Clique no botão
button.MouseButton1Click:Connect(toggleButton)

-- ==================== SISTEMA DE ARRASTAR COM DEDO ====================
local dragging = false
local dragStart
local startPos

button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = button.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        button.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

button.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

