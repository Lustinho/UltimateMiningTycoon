-- =============================================
-- UMT - Interface Simples Mobile (100% Sem Library Externa)
-- Botão circular arrastável + Auto Mine + ESP Integrado
-- =============================================

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- ==================== CONFIGURAÇÕES ====================
local Settings = {
    AutoMine = false,
    MiningRange = 150,
    OreHitbox = false,
    HitboxSize = 8,
}

local Tool = nil
local isOn = false
local highlights = {}  -- Armazena os ESP dos ores

local function GetTool()
    for _, v in pairs(character:GetChildren()) do
        if v:FindFirstChild("EquipRemote") or string.find(v.Name:lower(), "pickaxe") then
            return v
        end
    end
    return nil
end

-- ==================== BOTÃO CIRCULAR ARRASTÁVEL ====================
local screenGui = Instance.new("ScreenGui")
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 75, 0, 75)
button.Position = UDim2.new(1, -95, 1, -95)
button.BackgroundColor3 = Color3.fromRGB(220, 0, 0)
button.Text = "OFF"
button.TextColor3 = Color3.new(1, 1, 1)
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.BorderSizePixel = 0
button.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = button

local stroke = Instance.new("UIStroke")
stroke.Thickness = 4
stroke.Color = Color3.new(1, 1, 1)
stroke.Parent = button

-- ==================== TOGGLE ON/OFF ====================
local function toggle()
    isOn = not isOn
    if isOn then
        button.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        button.Text = "ON"
        print("✅ ESP + Auto Mine LIGADO")
    else
        button.BackgroundColor3 = Color3.fromRGB(220, 0, 0)
        button.Text = "OFF"
        print("⛔ ESP + Auto Mine DESLIGADO")
        
        -- Remove todos os highlights quando desliga
        for _, hl in pairs(highlights) do
            hl:Destroy()
        end
        highlights = {}
    end
end

button.MouseButton1Click:Connect(toggle)

-- Arrastar o botão
local dragging = false
local dragStart, startPos

button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = button.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

button.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- ==================== ESP SIMPLES (INTEGRADO) ====================
local function createESP(ore)
    if highlights[ore] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Adornee = ore
    highlight.FillColor = Color3.fromRGB(0, 255, 100)
    highlight.FillTransparency = 0.75   -- 25% de opacidade
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0.3
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = ore
    
    highlights[ore] = highlight
end

-- ==================== LOOP PRINCIPAL ====================
RunService.Heartbeat:Connect(function()
    if not isOn then return end
    
    Tool = GetTool()
    character = player.Character
    
    if not character or not character:FindFirstChild("HumanoidRootPart") or not Tool then return end
    
    local rootPos = character.HumanoidRootPart.Position
    
    for _, ore in pairs(Workspace.SpawnedBlocks:GetChildren()) do
        if ore:IsA("MeshPart") and ore:GetAttribute("MineId") then
            local dist = (ore:GetPivot().Position - rootPos).Magnitude
            
            if dist <= Settings.MiningRange and dist > 8 then
                -- ESP
                createESP(ore)
                
                -- Auto Mine
                local args = {1, ore:GetPivot().Position - Vector3.new(4,4,4)}
                pcall(function()
                    ReplicatedStorage.MadCommEvents[Tool:GetAttribute("MadCommId")].Activate:FireServer(unpack(args))
                end)
            end
        end
    end
end)

-- Hitbox (opcional)
Workspace.SpawnedBlocks.ChildAdded:Connect(function(ore)
    if Settings.OreHitbox and ore:IsA("MeshPart") then
        ore.Size = Vector3.new(Settings.HitboxSize, Settings.HitboxSize, Settings.HitboxSize)
    end
end)

print("✅ SCRIPT CARREGADO COM SUCESSO!")
print("   • Toque no botão para ligar/desligar")
print("   • Segure e arraste o botão para mover")
print("   • Quando estiver ON: Auto Mine + ESP ativados")
