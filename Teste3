-- =============================================
-- UMT - Interface Simples Mobile (Sem Library Externa)
-- Botão circular arrastável + Menu Farming
-- =============================================

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

-- ==================== CONFIGURAÇÕES ====================
local Settings = {
    AutoMine = false,
    AutoSell = false,
    MiningRange = 150,
    OreHitbox = false,
    HitboxSize = 8,
}

local Tool = nil

local function GetTool()
    for _, v in pairs(character:GetChildren()) do
        if v:FindFirstChild("EquipRemote") or string.find(v.Name:lower(), "pickaxe") then
            return v
        end
    end
    return nil
end

-- ==================== BOTÃO CIRCULAR ARRASTÁVEL ====================
local screenGui = Instance.new("ScreenGui")
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 70, 0, 70)
button.Position = UDim2.new(1, -90, 1, -90)
button.BackgroundColor3 = Color3.fromRGB(220, 0, 0)
button.Text = "OFF"
button.TextColor3 = Color3.new(1, 1, 1)
button.TextScaled = true
button.Font = Enum.Font.GothamBold
button.BorderSizePixel = 0
button.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = button

local stroke = Instance.new("UIStroke")
stroke.Thickness = 3
stroke.Color = Color3.new(1, 1, 1)
stroke.Parent = button

-- ==================== ESTADO DO BOTÃO ====================
local isOn = false

local function toggle()
    isOn = not isOn
    if isOn then
        button.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        button.Text = "ON"
        print("✅ Sistema LIGADO")
    else
        button.BackgroundColor3 = Color3.fromRGB(220, 0, 0)
        button.Text = "OFF"
        print("⛔ Sistema DESLIGADO")
    end
end

button.MouseButton1Click:Connect(toggle)

-- ==================== ARRASTAR O BOTÃO ====================
local dragging = false
local dragStart, startPos

button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = button.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

button.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

local Window = Library:CreateWindow({
    Title = "UMT - Farming System",
    Center = false,
    Size = UDim2.new(0, 340, 0, 380)
})

Window:SetPosition(UDim2.new(1, -360, 1, -420))

local MainTab = Window:AddTab("Main")
local FarmGroup = MainTab:AddLeftGroupbox("Farming")

-- ==================== TOGGLES E SLIDERS ====================

-- Auto Mine
FarmGroup:AddToggle("AutoMine", {Text = "Auto Mine", Default = false})
    :OnChanged(function(v)
        Settings.Farming.AutoMine = v
        print("Auto Mine:", v and "LIGADO" or "DESLIGADO")
    end)

-- Auto Sell
FarmGroup:AddToggle("AutoSell", {Text = "Auto Sell", Default = false})
    :OnChanged(function(v)
        Settings.Farming.AutoSell = v
        print("Auto Sell:", v and "LIGADO" or "DESLIGADO")
    end)

-- Mining Range
FarmGroup:AddSlider("MiningRange", {Text = "Mining Range", Default = 150, Min = 50, Max = 400, Rounding = 0})
    :OnChanged(function(v)
        Settings.Farming.AutoMineRange = v
        print("Mining Range atualizado para:", v)
    end)

-- Ore Hitbox
FarmGroup:AddToggle("OreHitbox", {Text = "Ore Hitbox", Default = false})
    :OnChanged(function(v)
        Settings.Farming.OreHitboxes = v
        
        -- Aplica o tamanho da hitbox em todos os ores existentes
        for _, ore in pairs(Workspace.SpawnedBlocks:GetChildren()) do
            if ore:IsA("MeshPart") then
                ore.Size = v and Vector3.new(Settings.Farming.OreHitboxesSize, Settings.Farming.OreHitboxesSize, Settings.Farming.OreHitboxesSize)
                         or Vector3.new(4.4, 4.4, 4.4)
            end
        end
        
        print("Ore Hitbox:", v and "LIGADO (Tamanho: " .. Settings.Farming.OreHitboxesSize .. ")" or "DESLIGADO")
    end)

-- Slider para mudar o tamanho da hitbox
FarmGroup:AddSlider("HitboxSize", {Text = "Hitbox Size", Default = 8, Min = 5, Max = 30, Rounding = 0})
    :OnChanged(function(v)
        Settings.Farming.OreHitboxesSize = v
        
        -- Se o hitbox estiver ativado, atualiza o tamanho imediatamente
        if Settings.Farming.OreHitboxes then
            for _, ore in pairs(Workspace.SpawnedBlocks:GetChildren()) do
                if ore:IsA("MeshPart") then
                    ore.Size = Vector3.new(v, v, v)
                end
            end
        end
        print("Hitbox Size atualizado para:", v)
    end)

-- ==================== LOOP PRINCIPAL - AUTO MINE ====================
RunService.Heartbeat:Connect(function()
    Tool = GetTool()
    character = player.Character
    
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    if Settings.Farming.AutoMine and Tool then
        local rootPos = character.HumanoidRootPart.Position
        
        for _, ore in pairs(Workspace.SpawnedBlocks:GetChildren()) do
            if ore:IsA("MeshPart") and ore:GetAttribute("MineId") then
                local distance = (ore:GetPivot().Position - rootPos).Magnitude
                
                if distance <= Settings.Farming.AutoMineRange and distance > 8 then
                    -- Executa a mineração
                    local args = {1, ore:GetPivot().Position - Vector3.new(4, 4, 4)}
                    pcall(function()
                        ReplicatedStorage.MadCommEvents[Tool:GetAttribute("MadCommId")].Activate:FireServer(unpack(args))
                    end)
                end
            end
        end
    end
end)

-- Atualiza hitbox quando novos ores aparecem
Workspace.SpawnedBlocks.ChildAdded:Connect(function(ore)
    if Settings.Farming.OreHitboxes and ore:IsA("MeshPart") then
        ore.Size = Vector3.new(Settings.Farming.OreHitboxesSize, Settings.Farming.OreHitboxesSize, Settings.Farming.OreHitboxesSize)
    end
end)

-- ==================== FINALIZAÇÃO ====================
Library:SetWatermark("UMT - Farming System")

print("✅ Interface simples mobile carregada!")
print("   • Toque no botão circular para ligar/desligar")
print("   • Segure e arraste para mover o botão")
